DISCORD_TOKEN=
DEFAULT_PREFIX=LR!
BOT_OWNER_ID=

# Supabase server-side credentials.
# Service role key is recommended for a private bot process.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Public Lavalink v4 node. Override these if you switch providers.
LAVALINK_NODE_NAME=Orbix Public Lavalink
LAVALINK_HOST=lavalinkv4.serenetia.com
LAVALINK_PORT=443
LAVALINK_PASSWORD=https://seretia.link/discord
LAVALINK_SECURE=true


# ── Dashboard bridge (optional) ──
# Set both to connect the bot to the dashboard backend (same VPS = localhost).
# Must match the backend's BOT_BRIDGE_SECRET.
DASHBOARD_BRIDGE_URL=http://localhost:4000
BOT_BRIDGE_SECRET=

# Set to true to auto-launch the dashboard backend as a child process when the
# bot starts (single `npm start` runs both on the same host). Leave unset/false
# if you run the backend separately (e.g. its own pm2 process).
START_DASHBOARD_BACKEND=false
